---
import { getPage } from '../lib/sdk-client';

const heroPage = await getPage('home-hero');

// Fallback values if page doesn't exist
const fallback = {
  title: 'Experience the Wild Like Never Before',
  description: 'Immerse yourself in breathtaking landscapes, encounter majestic wildlife up close, and embark on extraordinary adventures curated for the true explorer. With expert guides and sustainable travel, every journey with Springbok Expeditions promises unforgettable moments in the heart of nature.',
  heroImage: 'https://springbokexpeditions.com/wp-content/uploads/2025/02/wildebeest-and-zebras-at-the-serengeti-national-park-tanzania-africa.jpg',
  subtitle: 'Welcome to SpringBokExpeditions'
};

const data = heroPage ?? fallback;
---

<section class="hero" style={`background-image: url('${data.heroImage || fallback.heroImage}')`}>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <span class="hero-subtitle">{data.subtitle || fallback.subtitle}</span>
    <h1 class="hero-title">{data.title || fallback.title}</h1>
    <p class="hero-text">
      {data.description || fallback.description}
    </p>
    <div class="hero-buttons" set:html={data.defaultContent || ''}></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: url('https://springbokexpeditions.com/wp-content/uploads/2025/02/wildebeest-and-zebras-at-the-serengeti-national-park-tanzania-africa.jpg') center/cover no-repeat;
    text-align: center;
    padding-top: 80px;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.6));
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    color: #fff;
  }
  .hero-subtitle {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }
  .hero-text {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    opacity: 0.95;
  }
  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .hero-title { font-size: 2.25rem; }
    .hero-text { font-size: 1rem; }
  }
</style>