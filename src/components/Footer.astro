---
import { getPage } from '../lib/sdk-client';

const footerPage = await getPage('footer');

// Fallback footer content
const fallbackContent = `
  <div class="footer-top">
    <div class="footer-brand">
      <a href="#" class="footer-logo">
        <img src="https://springbokexpeditions.com/wp-content/uploads/2025/02/RT-02-01.png" alt="SpringbokExpeditions" width="160" loading="lazy">
      </a>
    </div>
    <nav class="footer-nav">
      <a href="#about">About Us</a>
      <a href="#destinations">Destination</a>
      <a href="#safaris">Safaris</a>
      <a href="#contact">Contact Us</a>
    </nav>
    <div class="footer-social">
      <a href="https://www.facebook.com/people/SpringBok-Expeditions/61574143054684/" aria-label="Facebook" target="_blank" rel="noopener">Facebook</a>
      <a href="https://wa.link/ppr59p" aria-label="WhatsApp" target="_blank" rel="noopener">WhatsApp</a>
      <a href="https://www.instagram.com/spring_bokexpeditions/" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>Copyright © 2025 SpringBokexpeditions. All rights reserved • Developed by Ab113Tech</p>
  </div>
`;

const footerContent = footerPage?.defaultContent || fallbackContent;
---
<footer class="site-footer" id="contact">
  <div class="container" set:html={footerContent}></div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer);
    color: #aaa;
    padding: 3rem 0 1.5rem;
  }
  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #333;
  }
  .footer-logo img { filter: brightness(1.2); }
  .footer-nav {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.875rem;
    color: #ddd;
    transition: color 0.3s;
  }
  .footer-nav a:hover { color: var(--color-accent); }
  .footer-social {
    display: flex;
    gap: 1rem;
  }
  .footer-social a {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #ddd;
    padding: 0.4rem 1rem;
    border: 1px solid #444;
    border-radius: 4px;
    transition: all 0.3s;
  }
  .footer-social a:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    font-size: 0.875rem;
  }
  @media (max-width: 768px) {
    .footer-top { flex-direction: column; text-align: center; }
    .footer-nav { justify-content: center; }
  }
</style>