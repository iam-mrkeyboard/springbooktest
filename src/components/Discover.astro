---
import { getPage } from '../lib/sdk-client';

const discoverPage = await getPage('home-discover');

const fallback = {
  subtitle: 'SpringBokexpeditions',
  title: 'Discover Tanzania with SpringBok Expeditions!',
  description: `<p>Embark on a thrilling safari, witness the <strong>Great Migration</strong>, or trek <strong>Mt. Kilimanjaro</strong>. Immerse yourself in local culture, meet the <strong>Maasai</strong>, and experience Tanzania's breathtaking landscapes.</p>
<p>With a focus on <strong>sustainable travel</strong>, we create unforgettable adventures while supporting local communities.</p>`,
  tagline: 'Your journey begins here!',
  cardImage: 'https://springbokexpeditions.com/wp-content/uploads/2025/02/wildebeest-and-zebras-at-the-serengeti-national-park-tanzania-africa.jpg',
  cardTitle: 'The Great Migration',
  cardDescription: 'Witness one of nature\'s greatest spectacles as over 1.5 million wildebeest, zebras, and gazelles move across the Serengeti.',
  cardLink: '#destinations',
  mainImage: 'https://springbokexpeditions.com/wp-content/uploads/2025/02/v-01-02.jpg',
};

const data = discoverPage ? {
  subtitle: discoverPage.subtitle || fallback.subtitle,
  title: discoverPage.title || fallback.title,
  description: discoverPage.description || fallback.description,
  tagline: discoverPage.tagline || fallback.tagline,
  cardImage: discoverPage.heroImage || fallback.cardImage,
  cardTitle: discoverPage.cardTitle || fallback.cardTitle,
  cardDescription: discoverPage.cardDescription || fallback.cardDescription,
  cardLink: discoverPage.cardLink || fallback.cardLink,
  mainImage: discoverPage.mainImage || fallback.mainImage,
} : fallback;
---
<section class="discover section-padding" id="about">
  <div class="container discover-inner">
    <div class="discover-text">
      <span class="section-subtitle" style="text-align:left;">{data.subtitle}</span>
      <h2 class="section-title" style="text-align:left;">{data.title}</h2>
      <div set:html={data.description}></div>
      <p class="discover-tagline">{data.tagline}</p>
      <div class="discover-cards">
        <div class="d-card">
          <img src={data.cardImage} alt={data.cardTitle} loading="lazy">
          <div class="d-card-body">
            <h4>{data.cardTitle}</h4>
            <p>{data.cardDescription}</p>
            <a href={data.cardLink}>Discover More</a>
          </div>
        </div>
      </div>
    </div>
    <div class="discover-image">
      <img src={data.mainImage} alt="Tanzania Safari" loading="lazy">
    </div>
  </div>
</section>

<style>
  .discover { background: #fff; }
  .discover-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .discover-text p {
    margin-bottom: 1rem;
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.8;
  }
  .discover-tagline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-primary) !important;
    margin: 1.5rem 0 !important;
  }
  .discover-image img {
    border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .discover-cards { margin-top: 2rem; }
  .d-card {
    background: var(--color-bg-alt);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .d-card img { width: 100%; height: 180px; object-fit: cover; }
  .d-card-body { padding: 1.5rem; }
  .d-card-body h4 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .d-card-body p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  .d-card-body a {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  @media (max-width: 992px) {
    .discover-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>