# =============================================
# SpringbokExpeditions - Environment Variables
# =============================================

# Authentication (REQUIRED - generate with: openssl rand --base64 16)
CMS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Site URL (REQUIRED)
ASTRO_SITE=https://your-domain.com

# =============================================
# MySQL Database (cPanel Production) 
# =============================================
CMS_MYSQL_HOST=localhost
CMS_MYSQL_PORT=3306
CMS_MYSQL_DATABASE=your_cpanel_database_name
CMS_MYSQL_USER=your_cpanel_database_user
CMS_MYSQL_PASSWORD=your_cpanel_database_password

# =============================================
# Local Dev Only (comment out the MySQL above)
# =============================================
# CMS_LIBSQL_URL=file:./studiocms.db

# =============================================
# Cloudflare R2 Storage (for image uploads)
# =============================================
CMS_S3_PROVIDER=CloudflareR2
CMS_S3_ACCESS_KEY_ID=your_r2_access_key_id
CMS_S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
CMS_S3_BUCKET_NAME=springbok-images
CMS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CMS_S3_PUBLIC_ENDPOINT=https://your-r2-public-url.r2.dev
CMS_S3_REGION=auto

# =============================================
# Optional: OAuth Providers
# =============================================
# CMS_GITHUB_CLIENT_ID=
# CMS_GITHUB_CLIENT_SECRET=
# CMS_DISCORD_CLIENT_ID=
# CMS_DISCORD_CLIENT_SECRET=
# CMS_GOOGLE_CLIENT_ID=
# CMS_GOOGLE_CLIENT_SECRET=
